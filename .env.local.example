# Supabase — ambil dari https://supabase.com/dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Service role key — JANGAN expose ke client, hanya untuk API routes server-side
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Secret untuk Vercel Cron Job — bebas isi sendiri, set juga di Vercel Environment Variables
CRON_SECRET=ganti_dengan_string_acak_panjang

# URL site untuk redirect setelah signout
NEXT_PUBLIC_SITE_URL=http://localhost:3000
